#!/bin/bash
set -ao pipefail

source ./etc/iceduck.env
. ./bin/icelib.sh
ECODE=0

_parseargs "$@"

case ${EXEC} in
	"file") 	cat $FNAME | \
				docker run --rm -i --network iceduck_net --env-file ./etc/iceduck.env --entrypoint /bin/sh  iceduck_shell ${CLIOPTS}
				ECODE=$?
				;;
	"clicmd")	echo "${CLICMD}" | \
				docker run --rm -i --network iceduck_net --env-file ./etc/iceduck.env --entrypoint /bin/sh  iceduck_shell ${CLIOPTS}
				ECODE=$?
				;;
	"shell") 	docker run --rm -it --network iceduck_net --env-file ./etc/iceduck.env --entrypoint /bin/sh  iceduck_shell ${CLIOPTS}
				ECODE=$?
				;;
esac

exit $ECODE
