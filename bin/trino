#!/bin/bash
set -ao pipefail

source ./etc/iceduck.env
. ./bin/icelib.sh
ECODE=0

_parseargs "$@"

case ${EXEC} in
	"file") 	cat $FNAME | \
				docker exec -i iceduck_trino trino ${CLIOPTS}
				ECODE=$?
				;;
	"clicmd")	echo "${CLICMD}" | \
				docker exec -i iceduck_trino trino ${CLIOPTS}
				ECODE=$?
				;;
	"shell") 	docker exec -it iceduck_trino trino ${CLIOPTS}
				ECODE=$?
				;;
esac

exit $ECODE
